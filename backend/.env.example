# Copy this file to .env and tweak values for your configuration
# cp .env.example .env

# --- General ---
RCH__BACKEND_NAME=reacher-backend
RUST_LOG=reacher=info

# --- Security ---
# Secret header required: x-reacher-secret
RCH__HEADER_SECRET=4d806a66310aa232fbf73b44837c1691

# --- Storage (Postgres) ---
# Format: postgres://user:password@host:port/dbname
RCH__STORAGE__POSTGRES__DB_URL=postgres://postgres:postgres@localhost:5432/reacher_db

# --- Worker (RabbitMQ) ---
# Set to 'true' to enable bulk verification
RCH__WORKER__ENABLE=true
RCH__WORKER__RABBITMQ__URL=amqp://guest:guest@localhost:5672

# --- Throttling (Optional) ---
# RCH__THROTTLE__MAX_REQUESTS_PER_SECOND=2
# RCH__THROTTLE__MAX_REQUESTS_PER_MINUTE=10
# RCH__THROTTLE__MAX_REQUESTS_PER_HOUR=100
# RCH__THROTTLE__MAX_REQUESTS_PER_DAY=1000

# --- Global Proxy (Optional SOCKS5) ---
# RCH__PROXY__HOST=1.2.3.4
# RCH__PROXY__PORT=1080
# RCH__PROXY__USERNAME=user
# RCH__PROXY__PASSWORD=pass
